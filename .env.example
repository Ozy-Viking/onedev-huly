# pod-onedev environment variables
# Copy to .env and fill in values

# ---- Service ----
PORT=3600
SERVICE_ID=onedev-service

# ---- Huly (match values from your huly_v7.conf) ----
SECRET=your-server-secret
ACCOUNTS_URL=http://account:3000
STATS_URL=http://stats:4900
STORAGE_CONFIG=minio|minio?accessKey=minioadmin&secretKey=minioadmin
HOST_ADDRESS=huly.example.com

# ---- OneDev ----
ONEDEV_WEBHOOK_SECRET=your-webhook-secret
ONEDEV_BASE_URL=https://onedev.example.com
ONEDEV_ACCESS_TOKEN=your-onedev-pat

# ---- Sync ----
# How often (ms) to poll Huly for outbound changes (Huly → OneDev).
# Lower values give faster sync at the cost of more API calls.
# OneDev → Huly sync is always instant via webhooks regardless of this setting.
# HULY_POLL_INTERVAL_MS=30000
